# Variables para PRODUCCIÓN (Railway).
# NO subas este archivo con valores reales. En Railway se ponen en
# Settings → Variables (una por una), no en un archivo .env.

DEBUG=False

# Clave secreta única (ya generada para ti; puedes regenerar otra).
SECRET_KEY=3&*h$&z4l=(@8bnk8198p_r0l_fgxw)$pr!*9w=_i#%rv3mi1c

# Dominios permitidos. El .up.railway.app cubre la URL temporal de Railway.
ALLOWED_HOSTS=iatechcorp.com,www.iatechcorp.com,.up.railway.app
CSRF_TRUSTED_ORIGINS=https://iatechcorp.com,https://www.iatechcorp.com

# --- Correo del formulario (API de Resend, NO SMTP) ---
# Railway bloquea el puerto SMTP saliente, por eso se usa la API HTTP de Resend.
# 1) Crea cuenta en https://resend.com (regístrate con iatechcol1006@gmail.com)
# 2) API Keys -> Create -> copia la clave (empieza con "re_")
RESEND_API_KEY=re_tu_api_key_de_resend

# Remitente. "onboarding@resend.dev" funciona SIN verificar dominio, pero solo
# puede enviar al correo de tu cuenta Resend. Para usar contacto@iatechcorp.com
# como remitente y enviar a cualquier dirección, verifica el dominio en Resend.
RESEND_FROM=IA Tech <onboarding@resend.dev>

# A dónde llegan los mensajes del formulario.
# Sin dominio verificado en Resend, debe ser el MISMO correo de tu cuenta Resend.
CONTACT_EMAIL=iatechcol1006@gmail.com
