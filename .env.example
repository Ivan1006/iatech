# Copia este archivo como `.env` y completa los valores.

DEBUG=True
SECRET_KEY=cambia-esta-clave-secreta
ALLOWED_HOSTS=127.0.0.1,localhost
# CSRF_TRUSTED_ORIGINS=https://tudominio.com

# --- Correo del formulario de contacto ---
# Para desarrollo puedes dejar el backend de consola (imprime el correo en la terminal):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Para enviar de verdad con Gmail, usa:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=tu_app_password_de_gmail
DEFAULT_FROM_EMAIL=tu_correo@gmail.com
CONTACT_EMAIL=contacto@iatech.com
